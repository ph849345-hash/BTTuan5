@model IEnumerable<BookStoreASM5.Models.Category>

<div class="category-sidebar">

    <!-- TITLE -->
    <div class="sidebar-title mb-3">

        <i class="fa-solid fa-layer-group me-2"></i>

        Danh mục sách

    </div>

    <!-- ALL BOOK -->
    <a asp-controller="Books"
       asp-action="Index"
       class="category-item d-flex justify-content-between align-items-center">

        <span>

            <i class="fa-solid fa-book-open me-2"></i>

            Tất cả sách

        </span>

    </a>

    <!-- CATEGORY LIST -->
    @foreach (var item in Model)
    {
        <a asp-controller="Books"
           asp-action="Index"
           asp-route-categoryId="@item.CategoryId"
           class="category-item d-flex justify-content-between align-items-center">

            <span>

                <i class="fa-solid fa-bookmark me-2"></i>

                @item.CategoryName

            </span>

            <span class="category-badge">

                @item.Books.Count

            </span>

        </a>
    }

</div>