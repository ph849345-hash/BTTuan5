@model IEnumerable<BookStoreASM5.Models.Book>
@using BookStoreASM5.Models

@{
    ViewData["Title"] = "Danh sách sách";
}

<!-- PAGE HEADER -->
<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">

    <div>
        <h2 class="fw-bold mb-1">
            <i class="fa-solid fa-book-open me-2 text-primary"></i>
            Danh sách sách
        </h2>

        <p class="text-muted mb-0">
            Khám phá những đầu sách nổi bật và mới nhất
        </p>
    </div>

    <a asp-action="Create" class="btn btn-success">
        <i class="fa-solid fa-plus"></i>
        Thêm sách mới
    </a>

</div>

<!-- SEARCH -->
<div class="bg-white p-4 rounded-4 shadow-sm mb-4">

    <form method="get" asp-action="Index">

        <div class="row g-3 align-items-center">

            <!-- SEARCH INPUT -->
            <div class="col-lg-5">
                <input type="text"
                       name="search"
                       value="@ViewBag.Search"
                       class="form-control"
                       placeholder="🔍 Tìm theo tên sách hoặc tác giả..." />
            </div>

            <!-- CATEGORY -->
            <div class="col-lg-4">
                <select name="categoryId" class="form-select">

                    <option value="">
                        -- Tất cả thể loại --
                    </option>

                    @foreach (var c in (List<Category>)ViewBag.Categories)
                    {
                        <option value="@c.CategoryId"
                                selected="@(ViewBag.CategoryId != null && (int)ViewBag.CategoryId == c.CategoryId)">

                            @c.CategoryName

                        </option>
                    }

                </select>
            </div>

            <!-- BUTTON -->
            <div class="col-lg-3 d-flex gap-2">

                <button type="submit" class="btn btn-primary w-100">
                    <i class="fa-solid fa-filter"></i>
                    Lọc
                </button>

                <a asp-action="Index" class="btn btn-secondary w-100">
                    <i class="fa-solid fa-rotate-left"></i>
                    Reset
                </a>

            </div>

        </div>

    </form>

</div>

<!-- BOOK LIST -->
<div class="row">

    @foreach (var item in Model)
    {
        <div class="col-xl-4 col-md-6 mb-4">

            <div class="card h-100">

                <!-- IMAGE -->
                <div class="overflow-hidden">

                    <img src="@(string.IsNullOrEmpty(item.Image) ? "/images/no-image.png" : item.Image)"
                         class="card-img-top" />

                </div>

                <!-- BODY -->
                <div class="card-body d-flex flex-column">

                    <h5 class="card-title">
                        @item.Title
                    </h5>

                    <p class="card-text mb-2">
                        <i class="fa-solid fa-user-pen me-1 text-primary"></i>
                        <strong>Tác giả:</strong>
                        @item.Author
                    </p>

                    <p class="card-text mb-2">

                        <i class="fa-solid fa-layer-group me-1 text-success"></i>

                        <strong>Thể loại:</strong>
                        @item.Category?.CategoryName

                    </p>

                    <p class="card-text mt-2 fs-5 text-danger">

                        @item.Price.ToString("N0") VND

                    </p>

                    <!-- PUSH FOOTER DOWN -->
                    <div class="mt-auto"></div>

                </div>

                <!-- FOOTER -->
                <div class="card-footer bg-white">

                    <div class="d-flex justify-content-between gap-2">

                        <a asp-action="Details"
                           asp-route-id="@item.Id"
                           class="btn btn-info btn-sm w-100">

                            <i class="fa-solid fa-eye"></i>
                            Chi tiết

                        </a>

                        <a asp-action="Edit"
                           asp-route-id="@item.Id"
                           class="btn btn-warning btn-sm w-100">

                            <i class="fa-solid fa-pen"></i>
                            Sửa

                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@item.Id"
                           class="btn btn-danger btn-sm w-100">

                            <i class="fa-solid fa-trash"></i>
                            Xóa

                        </a>

                    </div>

                </div>

            </div>

        </div>
    }

</div>

<!-- EMPTY -->
@if (!Model.Any())
{
    <div class="text-center py-5">

        <img src="https://cdn-icons-png.flaticon.com/512/7486/7486740.png"
             width="120"
             class="mb-3 opacity-75" />

        <h4 class="fw-bold">
            Không tìm thấy sách
        </h4>

        <p class="text-muted">
            Hãy thử tìm kiếm với từ khóa khác
        </p>

    </div>
}