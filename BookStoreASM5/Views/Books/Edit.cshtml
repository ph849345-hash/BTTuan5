@model BookStoreASM5.ViewModels.BookFormViewModel

@{
    ViewData["Title"] = "Sửa sách";
}

<div class="container-fluid">

    <!-- PAGE HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">

        <div>

            <h2 class="fw-bold mb-1">

                <i class="fa-solid fa-pen-to-square me-2 text-warning"></i>
                Chỉnh sửa sách

            </h2>

            <p class="text-muted mb-0">
                Cập nhật thông tin sách trong hệ thống
            </p>

        </div>

        <a asp-action="Index"
           class="btn btn-secondary">

            <i class="fa-solid fa-arrow-left"></i>
            Quay lại

        </a>

    </div>

    <!-- FORM -->
    <div class="bg-white rounded-4 shadow-sm p-4 p-lg-5">

        <form asp-action="Edit"
              method="post"
              enctype="multipart/form-data">

            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly"
                 class="alert alert-danger"></div>

            <div class="row g-4">

                <!-- LEFT -->
                <div class="col-lg-8">

                    <!-- TITLE -->
                    <div class="mb-4">

                        <label asp-for="Title"
                               class="form-label fw-semibold">

                            <i class="fa-solid fa-book me-2 text-primary"></i>
                            Tên sách

                        </label>

                        <input asp-for="Title"
                               class="form-control form-control-lg"
                               placeholder="Nhập tên sách..." />

                        <span asp-validation-for="Title"
                              class="text-danger"></span>

                    </div>

                    <!-- AUTHOR -->
                    <div class="mb-4">

                        <label asp-for="Author"
                               class="form-label fw-semibold">

                            <i class="fa-solid fa-user-pen me-2 text-info"></i>
                            Tác giả

                        </label>

                        <input asp-for="Author"
                               class="form-control form-control-lg"
                               placeholder="Nhập tên tác giả..." />

                        <span asp-validation-for="Author"
                              class="text-danger"></span>

                    </div>

                    <!-- PRICE + CATEGORY -->
                    <div class="row">

                        <!-- PRICE -->
                        <div class="col-md-6 mb-4">

                            <label asp-for="Price"
                                   class="form-label fw-semibold">

                                <i class="fa-solid fa-money-bill-wave me-2 text-success"></i>
                                Giá bán

                            </label>

                            <input asp-for="Price"
                                   class="form-control form-control-lg"
                                   placeholder="Ví dụ: 120000" />

                            <span asp-validation-for="Price"
                                  class="text-danger"></span>

                        </div>

                        <!-- CATEGORY -->
                        <div class="col-md-6 mb-4">

                            <label asp-for="CategoryId"
                                   class="form-label fw-semibold">

                                <i class="fa-solid fa-layer-group me-2 text-warning"></i>
                                Thể loại

                            </label>

                            <select asp-for="CategoryId"
                                    asp-items="Model.Categories"
                                    class="form-select form-select-lg">
                            </select>

                            <span asp-validation-for="CategoryId"
                                  class="text-danger"></span>

                        </div>

                    </div>

                    <!-- DESCRIPTION -->
                    <div class="mb-4">

                        <label asp-for="Description"
                               class="form-label fw-semibold">

                            <i class="fa-solid fa-align-left me-2 text-secondary"></i>
                            Mô tả sách

                        </label>

                        <textarea asp-for="Description"
                                  class="form-control"
                                  rows="6"
                                  placeholder="Nhập mô tả chi tiết cho sách..."></textarea>

                        <span asp-validation-for="Description"
                              class="text-danger"></span>

                    </div>

                </div>

                <!-- RIGHT -->
                <div class="col-lg-4">

                    <div class="bg-light rounded-4 p-4 h-100">

                        <h5 class="fw-bold mb-4">

                            <i class="fa-solid fa-image me-2 text-primary"></i>
                            Ảnh sách

                        </h5>

                        <!-- IMAGE PREVIEW -->
                        <div class="text-center mb-4">

                            <img id="previewImage"
                                 src="@(string.IsNullOrEmpty(Model.CurrentImage) ? "/images/no-image.png" : Model.CurrentImage)"
                                 class="img-fluid rounded-4 shadow-sm border"
                                 style="height: 320px; object-fit: cover;" />

                        </div>

                        <!-- CURRENT IMAGE -->
                        <div class="mb-3">

                            <div class="small text-muted mb-2">

                                Ảnh hiện tại

                            </div>

                            <div class="fw-semibold text-dark">

                                @(string.IsNullOrEmpty(Model.CurrentImage)
                                    ? "Chưa có ảnh"
                                    : "Đã có ảnh")

                            </div>

                        </div>

                        <!-- FILE INPUT -->
                        <div class="mb-3">

                            <label asp-for="ImageFile"
                                   class="form-label fw-semibold">

                                Chọn ảnh mới

                            </label>

                            <input asp-for="ImageFile"
                                   type="file"
                                   class="form-control"
                                   accept="image/*"
                                   onchange="previewFile(event)" />

                            <span asp-validation-for="ImageFile"
                                  class="text-danger"></span>

                        </div>

                        <div class="small text-muted">

                            Để trống nếu không muốn thay đổi ảnh.

                        </div>

                    </div>

                </div>

            </div>

            <!-- BUTTON -->
            <div class="mt-5 d-flex flex-wrap gap-3">

                <button type="submit"
                        class="btn btn-warning btn-lg px-5">

                    <i class="fa-solid fa-floppy-disk me-2"></i>
                    Cập nhật

                </button>

                <a asp-action="Index"
                   class="btn btn-secondary btn-lg px-5">

                    <i class="fa-solid fa-xmark me-2"></i>
                    Hủy

                </a>

            </div>

        </form>

    </div>

</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    <script>

        function previewFile(event) {

            const reader = new FileReader();

            reader.onload = function () {

                const output = document.getElementById('previewImage');

                output.src = reader.result;
            };

            reader.readAsDataURL(event.target.files[0]);
        }

    </script>

}